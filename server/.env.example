# Application Settings
APP_NAME=Interview AI
DEBUG=True
ENVIRONMENT=development

# AWS Configuration
AWS_REGION=us-east-1
# (Optional) Cognito User Pool settings for hosted auth
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# AWS Credentials - choose one method below (env vars, profile, or IAM role)
# For local development you can set the following env vars:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional session token when using temporary credentials
AWS_SESSION_TOKEN=
# Or set `AWS_PROFILE` to use a named profile from ~/.aws/credentials
AWS_PROFILE=

# Brevo Email Configuration (for email verification)
BREVO_API_KEY=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
BREVO_SENDER_EMAIL=ganesh9876637@gmail.com
BREVO_SENDER_NAME=Interview AI
EMAIL_VERIFICATION_REDIRECT_URL=http://localhost:5173/login

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4
AI_TEMPERATURE=0.3
AI_MAX_RETRIES=2
AI_TIMEOUT_SEC=30

# Speech-to-Text
STT_PROVIDER=openai
STT_MODEL=whisper-1
STT_MAX_RETRIES=2
STT_TIMEOUT_SEC=30

# Audio Settings
MAX_AUDIO_SIZE_MB=25
AUDIO_QUALITY_THRESHOLD=0.6
SUPPORTED_AUDIO_FORMATS=["wav","mp3","m4a","webm"]

# Session Settings
DEFAULT_SESSION_DURATION_MIN=30
MIN_QUESTIONS_PER_SESSION=3
MAX_QUESTIONS_PER_SESSION=10

# Evaluation Settings
EVALUATION_TIMEOUT_SEC=10
MIN_EVAL_CONFIDENCE=0.5

# Privacy & Retention
AUDIO_RETENTION_DAYS=30
TRANSCRIPT_RETENTION_DAYS=90
REQUIRE_AUDIO_CONSENT=True

# Performance Targets
TARGET_EVAL_LATENCY_P95_SEC=10.0
TARGET_STT_LATENCY_P95_SEC=5.0

# Analytics
ENABLE_ANALYTICS=True
LOG_LEVEL=INFO

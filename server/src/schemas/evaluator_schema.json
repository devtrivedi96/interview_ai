{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interview Answer Evaluation",
  "description": "Strict JSON schema for LLM evaluation output",
  "type": "object",
  "required": [
    "scores",
    "composite_score",
    "strengths",
    "improvements",
    "next_question_strategy",
    "eval_confidence"
  ],
  "properties": {
    "scores": {
      "type": "object",
      "description": "Per-dimension rubric scores (0-5 scale)",
      "required": [
        "dimension_1",
        "dimension_2",
        "dimension_3",
        "dimension_4",
        "dimension_5"
      ],
      "properties": {
        "dimension_1": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "dimension_2": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "dimension_3": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "dimension_4": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "dimension_5": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        }
      },
      "additionalProperties": false
    },
    "composite_score": {
      "type": "number",
      "description": "Weighted average of all dimension scores",
      "minimum": 0,
      "maximum": 5
    },
    "strengths": {
      "type": "array",
      "description": "List of specific strengths observed",
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 200
      },
      "minItems": 1,
      "maxItems": 5
    },
    "improvements": {
      "type": "array",
      "description": "List of specific areas for improvement",
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 200
      },
      "minItems": 1,
      "maxItems": 5
    },
    "next_question_strategy": {
      "type": "string",
      "description": "Recommended difficulty adjustment",
      "enum": ["easier", "same", "harder"]
    },
    "eval_confidence": {
      "type": "number",
      "description": "Evaluator confidence in the assessment (0-1)",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
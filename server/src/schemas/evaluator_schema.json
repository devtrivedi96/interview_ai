{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interview Answer Evaluation",
  "description": "Strict JSON schema for LLM evaluation output",
  "type": "object",
  "required": [
    "scores",
    "composite_score",
    "strengths",
    "improvements",
    "next_question_strategy",
    "eval_confidence"
  ],
  "properties": {
    "scores": {
      "type": "object",
      "required": ["dimension_1", "dimension_2", "dimension_3", "dimension_4", "dimension_5"],
      "properties": {
        "dimension_1": {"type": "number", "minimum": 0, "maximum": 5},
        "dimension_2": {"type": "number", "minimum": 0, "maximum": 5},
        "dimension_3": {"type": "number", "minimum": 0, "maximum": 5},
        "dimension_4": {"type": "number", "minimum": 0, "maximum": 5},
        "dimension_5": {"type": "number", "minimum": 0, "maximum": 5}
      }
    },
    "composite_score": {"type": "number", "minimum": 0, "maximum": 5},
    "strengths": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 5},
    "improvements": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 5},
    "next_question_strategy": {"type": "string", "enum": ["easier", "same", "harder"]},
    "eval_confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
